# --- Fullscreen + Transparency ---
# "non-native" was added in Ghostty 1.3.0 — launches directly into
# non-native fullscreen (no separate Space), which allows compositing
# so background-opacity and blur work correctly.
# "true" would trigger macOS native fullscreen, which blocks transparency.
fullscreen = non-native
macos-non-native-fullscreen = true
background-opacity = 0.7
background-blur-radius = 20

# --- Font ---
font-family = JetBrainsMono Nerd Font
font-size = 20

# --- Theme ---
theme = Catppuccin Mocha
