#!/usr/bin/env bash
#
# claude-tcc-heal — stop the recurring macOS "wants to access data from other apps" (TCC) popup,
# and stop losing the `claude` launcher to "command not found" when Claude Code's updater churns.
#
# ROOT CAUSE
#   Claude Code's auto-updater installs each version to a NEW path under versions/, and its own
#   cleanup/updater will create AND DELETE the ClaudeCode.app bundle it maintains. macOS TCC keys
#   permission grants to an app's identity, so every bundle replacement looks like a brand-new app
#   and re-prompts — and if the bundle is ever deleted outright, a launcher symlink pointed into
#   it goes dangling ("command not found").
#
# THE FIX
#   Anchor the stable identity OUTSIDE anything Claude Code manages: ~/.local/share/claude-stable/
#   is a plain directory this script owns; Claude's updater never touches it. In it we keep
#   claude-stable/claude as a HARD LINK to the current versions/NNN binary. A stable path == a
#   stable TCC identity, so the Full Disk Access grant finally sticks — and because the anchor
#   dir can never be deleted out from under us by an update, the launcher can't go dangling either.
#   ~/.local/bin/claude symlinks to that anchor.
#
#   Hard links only work within one filesystem/volume. ~/.local/share/claude-stable and
#   ~/.local/share/claude/versions are both under ~/.local/share, i.e. the same volume — this
#   script checks that with `stat -f %d` (device id) and fails loudly rather than silently
#   falling back to a copy if that ever stops being true.
#
#   DISABLE_AUTOUPDATER=1 (exported from dotfiles .zshrc) still reduces version churn, but the
#   updater flips ~/.claude/settings.json's autoUpdate back to true on its own, so this script no
#   longer depends on winning that fight — it just makes any update non-breaking.
#
# This script is idempotent: safe to run any number of times. It only ever moves a symlink and
# refreshes one hard link — nothing destructive. It is also run automatically by the
# com.stillpoint-labs.claude-tcc-heal launchd agent (zsh/launchd/) whenever versions/ or the
# ~/.local/bin/claude launcher changes, so healing happens even with no shell open.
#
# ONE-TIME MANUAL STEP (do this once per machine, after the first run):
#   System Settings > Privacy & Security > Full Disk Access
#     -> add / enable:  ~/.local/share/claude-stable/claude
#   This REPLACES any prior grant on ~/.local/share/claude/ClaudeCode.app — that bundle is no
#   longer the stable identity and can be safely ignored (or left alone; this script does not
#   touch it).

set -euo pipefail

share="$HOME/.local/share/claude"
versions="$share/versions"
stable_dir="$HOME/.local/share/claude-stable"
anchor="$stable_dir/claude"
link="$HOME/.local/bin/claude"

die() { printf 'claude-tcc-heal: %s\n' "$1" >&2; exit 1; }

[[ "$(uname)" == "Darwin" ]] || die "macOS only (TCC is an Apple thing)."
[[ -d "$versions" ]] || die "no $versions — expected the native Claude Code install layout."

# Pick the newest version binary (version-sorted).
current="$(ls -1 "$versions" 2>/dev/null | sort -V | tail -1)"
[[ -n "$current" ]] || die "no version binaries found in $versions."
src="$versions/$current"
[[ -x "$src" ]] || die "$src is not an executable file."

mkdir -p "$stable_dir"

# Hard links require the source and target to be on the same filesystem/volume.
src_dev="$(stat -f %d "$src")"
stable_dev="$(stat -f %d "$stable_dir")"
[[ "$src_dev" == "$stable_dev" ]] || die "$stable_dir is on a different volume (dev $stable_dev) than $src (dev $src_dev) — hard link would fail."

# (Re)establish the stable anchor as a HARD LINK to the current version.
# Hard link — not symlink — so the stable path is itself a real Mach-O with a fixed identity.
if [[ -e "$anchor" && "$(stat -f %i "$anchor")" == "$(stat -f %i "$src")" ]]; then
    echo "stable anchor already at current version ($current)"
else
    ln -f "$src" "$anchor"
    echo "linked stable anchor  ->  version $current"
fi

# Point the launcher symlink at the stable anchor.
mkdir -p "$(dirname "$link")"
if [[ "$(readlink "$link" 2>/dev/null || true)" == "$anchor" ]]; then
    echo "launcher symlink already stable ($link)"
else
    ln -sf "$anchor" "$link"
    echo "repointed launcher    ->  $anchor"
fi

cat <<EOF

Done. Two things to finish, ONCE, on this machine:
  1. System Settings > Privacy & Security > Full Disk Access
     -> add / enable:  $anchor
     (replaces any prior grant on $share/ClaudeCode.app — that bundle is no longer used)
  2. Load the self-heal launchd agent so this runs automatically on future updates:
       cp $HOME/.config/dotfiles/zsh/launchd/com.stillpoint-labs.claude-tcc-heal.plist \\
          $HOME/Library/LaunchAgents/com.stillpoint-labs.claude-tcc-heal.plist
       launchctl bootstrap gui/\$(id -u) \\
          $HOME/Library/LaunchAgents/com.stillpoint-labs.claude-tcc-heal.plist

After this the grant sticks, the launcher can't go dangling, and the popup stops.
EOF
