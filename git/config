[user]
	name = Noah Goodrich
	# Email is machine-local — set in ~/.gitconfig.local (gitignored, not in this repo).
	# install.sh creates a stub on first run. Set with:
	#   git config -f ~/.gitconfig.local user.email "your@email.com"

[include]
	path = ~/.gitconfig.local

[core]
    editor = nvim
    autocrlf = input
    excludesfile = ~/.config/git/ignore

[init]
    defaultBranch = main

[push]
    default = current
    autoSetupRemote = true

[pull]
    rebase = false

[fetch]
    prune = true

[diff]
    tool = nvim

[merge]
    tool = nvim
    conflictstyle = diff3

[alias]
    st = status
    co = checkout
    br = branch
    lg = log --oneline --graph --decorate --all
    undo = reset HEAD~1 --mixed
    amend = commit --amend --no-edit
    aliases = config --get-regexp alias

[color]
    ui = auto
